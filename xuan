local FIREBASE_URL = "https://e5alr9-default-rtdb.asia-southeast1.firebasedatabase.app/"
_G.lastBroadcast = _G.lastBroadcast or ""

local function httpRequest(method, url, body)
    local req = syn and syn.request or http_request or request or (http and http.request)
    if not req then 
        warn("[MyCommander] 找不到 HTTP 请求函数")
        return nil 
    end
    local success, result = pcall(function()
        return req({
            Url = url,
            Method = method,
            Headers = {["Content-Type"] = "application/json"},
            Body = body and HttpService:JSONEncode(body) or nil,
            Timeout = 5
        })
    end)
    if success and result then
        return result
    else
        warn("[MyCommander] HTTP 请求失败:", result)
        return nil
    end
end

local function sendBroadcast(message)
    if message == "" then
        showNotice("⚠️ 消息不能为空", true)
        return
    end
    local success = pcall(function()
        httpRequest("PUT", FIREBASE_URL .. "broadcast.json", {
            msg = message,
            sender = lp.Name,
            time = os.time()
        })
    end)
    if success then
        showNotice("✅ 广播已发送", true)
        if broadcastGui then
            broadcastGui:Destroy()
            broadcastWindowActive = false
            broadcastGui = nil
        end
    else
        showNotice("❌ 广播发送失败", true)
    end
end

