-- ==================== ESP 核心函数（修复距离显示） ====================
local function CreateEsp(Char, Color, Text, ParentPart, YOffset)
    safeCall(function()
        if not Char or not Char.Parent then return end
        if not ParentPart or not ParentPart:IsA("BasePart") then return end
        if Char:FindFirstChild("ESP_Highlight") and ParentPart:FindFirstChild("ESP") then return end

        local highlight = Instance.new("Highlight")
        highlight.Name = "ESP_Highlight"
        highlight.Adornee = Char
        highlight.FillColor = Color
        highlight.FillTransparency = 0.5
        highlight.OutlineColor = Color
        highlight.OutlineTransparency = 0
        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        highlight.Enabled = true
        highlight.Parent = Char

        local billboard = Instance.new("BillboardGui")
        billboard.Name = "ESP"
        billboard.Size = UDim2.new(0, 100, 0, 50)
        billboard.AlwaysOnTop = true
        billboard.StudsOffset = Vector3.new(0, YOffset, 0)
        billboard.Adornee = ParentPart
        billboard.Enabled = true
        billboard.Parent = ParentPart

        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(1, 0, 1, 0)
        label.BackgroundTransparency = 1
        label.Text = tostring(Text) or ""
        label.TextColor3 = Color
        label.TextScaled = true
        label.Font = Enum.Font.SourceSansBold
        label.Parent = billboard

        local espKey = {Char, ParentPart}
        espObjects[espKey] = {highlight, billboard}

        task.spawn(function()
            local Camera = Workspace.CurrentCamera
            while highlight.Parent and billboard.Parent and ParentPart.Parent and Camera do
                local cameraPosition = Camera.CFrame.Position
                local distance = (cameraPosition - ParentPart.Position).Magnitude
                local safeText = tostring(Text) or ""
                
                if distanceEspEnabled then
                    label.Text = safeText .. " " .. tostring(math.floor(distance + 0.5)) .. "m"
                else
                    label.Text = safeText
                end
                task.wait(0.1)
            end
            if highlight then pcall(function() highlight:Destroy() end) end
            if billboard then pcall(function() billboard:Destroy() end) end
            for k in pairs(espObjects) do
                if k[1] == Char or k[2] == ParentPart then
                    espObjects[k] = nil
                end
            end
        end)
    end)
end

local function RemoveEsp(Char, ParentPart)
    safeCall(function()
        if Char then
            local highlight = Char:FindFirstChild("ESP_Highlight")
            if highlight then pcall(function() highlight:Destroy() end) end
        end
        if ParentPart then
            local billboard = ParentPart:FindFirstChild("ESP")
            if billboard then pcall(function() billboard:Destroy() end) end
        end
        for k in pairs(espObjects) do
            if k[1] == Char or k[2] == ParentPart then
                espObjects[k] = nil
            end
        end
    end)
end

local function handlePlayerEsp(plr)
    safeCall(function()
        if plr == lp then return end
        local function applyToCharacter(char)
            if playerEspEnabled and char and char:FindFirstChild("Head") then
                CreateEsp(char, Color3.new(0.4, 0.8, 0.4), plr.Name, char.Head, 1)
            end
        end
        if plr.Character then
            applyToCharacter(plr.Character)
        end
        plr.CharacterAdded:Connect(function(newChar)
            task.wait(0.5)
            applyToCharacter(newChar)
        end)
        plr.CharacterRemoving:Connect(function(oldChar)
            if oldChar and oldChar:FindFirstChild("Head") then
                RemoveEsp(oldChar, oldChar.Head)
            end
        end)
    end)
end

local function refreshPlayerEsp()
    safeCall(function()
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= lp then
                handlePlayerEsp(plr)
            end
        end
    end)
end

local function clearPlayerEsp()
    safeCall(function()
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr.Character and plr.Character:FindFirstChild("Head") then
                RemoveEsp(plr.Character, plr.Character.Head)
            end
        end
    end)
end

local function refreshBotEsp()
    safeCall(function()
        local gameFolder = Workspace:FindFirstChild("Game")
        if not gameFolder then return end
        local playersFolder = gameFolder:FindFirstChild("Players")
        if not playersFolder then return end

        for _, bot in ipairs(playersFolder:GetChildren()) do
            if bot:IsA("Model") and bot:FindFirstChild("Hitbox") then
                local hitbox = bot.Hitbox
                if botEspEnabled then
                    if not hitbox:FindFirstChild("ESP") then
                        CreateEsp(bot, Color3.new(0.8, 0.2, 0.2), bot.Name, hitbox, -2)
                    end
                else
                    RemoveEsp(bot, hitbox)
                end
            end
        end
    end)
end

local function clearBotEsp()
    safeCall(function()
        local gameFolder = Workspace:FindFirstChild("Game")
        if not gameFolder then return end
        local playersFolder = gameFolder:FindFirstChild("Players")
        if not playersFolder then return end
        for _, bot in ipairs(playersFolder:GetChildren()) do
            if bot:IsA("Model") and bot:FindFirstChild("Hitbox") then
                RemoveEsp(bot, bot.Hitbox)
            end
        end
    end)
end

