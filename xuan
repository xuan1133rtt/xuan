                    local state = inGameCharacter:GetAttribute("State") or ""
                    local isDowned = inGameCharacter:GetAttribute("Downed") or (state == "Downed") or (state == "Dead")
                    if isDead or isDowned then
                        reviveRemote:FireServer(true)
                        task.wait(2)
                    end
                end
            end)
        end
        task.wait(0.5)
    end
end)

-- ==================== 智慧光影引擎 (可開關) ====================
local ENGINE_FOLDER_NAME = "XUAN_GraphicsEngine"
local CLOUDS_NAME = "XUAN_RealisticClouds"

local function toggleGraphicsEngine()
    -- 檢查是否已啟用
    if Lighting:FindFirstChild(ENGINE_FOLDER_NAME) then
        -- ========== 關閉模式：恢復原始設定 ==========
        Lighting:SetAttribute("Engine_Active", false)
        Lighting[ENGINE_FOLDER_NAME]:Destroy()

        if Terrain:FindFirstChild(CLOUDS_NAME) then
            Terrain[CLOUDS_NAME]:Destroy()
        end

        -- 恢復 Lighting 設定
        if Lighting:GetAttribute("Orig_Saved") then
            Lighting.ClockTime = Lighting:GetAttribute("Orig_ClockTime")
            Lighting.GeographicLatitude = Lighting:GetAttribute("Orig_GeographicLatitude")
            Lighting.Brightness = Lighting:GetAttribute("Orig_Brightness")
            Lighting.GlobalShadows = Lighting:GetAttribute("Orig_GlobalShadows")
            Lighting.ShadowSoftness = Lighting:GetAttribute("Orig_ShadowSoftness")
            Lighting.OutdoorAmbient = Lighting:GetAttribute("Orig_OutdoorAmbient")
            Lighting.EnvironmentDiffuseScale = Lighting:GetAttribute("Orig_EnvDiffuse")
            Lighting.EnvironmentSpecularScale = Lighting:GetAttribute("Orig_EnvSpecular")
        end

        -- 恢復零件反射率
        for _, obj in pairs(Workspace:GetDescendants()) do
            if obj:IsA("BasePart") and obj:GetAttribute("Orig_Reflectance") then
                obj.Reflectance = obj:GetAttribute("Orig_Reflectance")
            end
        end

        showNotice("🔴 光影引擎已關閉", true)
        return
    end

    -- ========== 開啟模式：套用光影增強 ==========
    showNotice("🟢 光影引擎啟動中...", true)

    Lighting:SetAttribute("Engine_Active", true)

    -- 備份原始 Lighting 設定
