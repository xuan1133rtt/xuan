    local function formatTime(clockTime)
        local hours = math.floor(clockTime)
        local mins = math.floor((clockTime - hours) * 60)
        return string.format("%02d:%02d", hours, mins)
    end

    -- 更新滑桿與時間
    local dragging = false
    local function updateSlider(input)
        local trackPos = track.AbsolutePosition.X
        local trackSize = track.AbsoluteSize.X
        local mousePos = input.Position.X
        local percentage = clamp((mousePos - trackPos) / trackSize, 0, 1)

        fill.Size = UDim2.new(percentage, 0, 1, 0)
        knob.Position = UDim2.new(percentage, 0, 0.5, 0)

        local newTime = percentage * 24
        Lighting.ClockTime = newTime
        timeLabel.Text = "目前時間: " .. formatTime(newTime)
    end

    -- 初始化滑桿位置
    local function initSlider()
        local currentTime = Lighting.ClockTime
        local percentage = currentTime / 24
        fill.Size = UDim2.new(percentage, 0, 1, 0)
        knob.Position = UDim2.new(percentage, 0, 0.5, 0)
        timeLabel.Text = "目前時間: " .. formatTime(currentTime)
    end
    initSlider()

    -- 事件監聽
    knob.MouseButton1Down:Connect(function()
        dragging = true
    end)

    -- 修正：track 是 Frame，需使用 InputBegan 監聽滑鼠點擊
    track.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            local mousePos = UIS:GetMouseLocation()
            updateSlider({Position = mousePos})
        end
    end)

    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    UIS.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            updateSlider(input)
        end
    end)

    restoreBtn.MouseButton1Click:Connect(function()
        if _G.OriginalClockTime then
            Lighting.ClockTime = _G.OriginalClockTime
            initSlider()
        end
    end)

    timeControlWindowActive = true
    timeControlGui = sg
end

