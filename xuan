        local valueLabel = Instance.new("TextLabel", sliderFrame)
        valueLabel.Size = UDim2.new(0, 50, 0, 25)
        valueLabel.Position = UDim2.new(1, -55, 0, 5)
        valueLabel.Text = tostring(defaultValue) .. suffix
        valueLabel.TextColor3 = Color3.new(1,1,1)
        valueLabel.BackgroundTransparency = 1
        valueLabel.TextSize = 14
        valueLabel.Font = Enum.Font.GothamSemibold
        valueLabel.TextXAlignment = Enum.TextXAlignment.Right

        -- 垂直滑桿背景
        local barBg = Instance.new("Frame", sliderFrame)
        barBg.Size = UDim2.new(0, 12, 0.6, 0)
        barBg.Position = UDim2.new(0.5, -6, 0.2, 0)
        barBg.BackgroundColor3 = Color3.fromRGB(50,50,60)
        barBg.BackgroundTransparency = 0.5
        Instance.new("UICorner", barBg).CornerRadius = UDim.new(1, 0)

        -- 滑桿填充（從底部往上）
        local barFill = Instance.new("Frame", barBg)
        barFill.Size = UDim2.new(1, 0, (defaultValue - range[1]) / (range[2] - range[1]), 0)
        barFill.Position = UDim2.new(0, 0, 1, -barFill.Size.Y.Offset)
        barFill.BackgroundColor3 = Color3.fromRGB(100,150,255)
        Instance.new("UICorner", barFill).CornerRadius = UDim.new(1, 0)

        -- 拖曳按鈕
        local dragButton = Instance.new("TextButton", sliderFrame)
        dragButton.Size = UDim2.new(0, 20, 0, 20)
        dragButton.Position = UDim2.new(0.5, -10, 0.2 + 0.6 * (1 - (defaultValue - range[1]) / (range[2] - range[1])), 0)
        dragButton.BackgroundColor3 = Color3.new(1,1,1)
        dragButton.Text = ""
        dragButton.ZIndex = 2
        Instance.new("UICorner", dragButton).CornerRadius = UDim.new(1, 0)

        local currentValue = defaultValue
        local dragging = false
        local dragConnection = nil

        local function updateSlider(pos)
            local bgPos = barBg.AbsolutePosition.Y
            local bgSize = barBg.AbsoluteSize.Y
            local mouseY = pos.Y
            local ratio = clamp((mouseY - bgPos) / bgSize, 0, 1)
            ratio = 1 - ratio  -- 轉換成從底部算起的比例
            local newValue = math.floor((range[1] + (range[2] - range[1]) * ratio) / increment + 0.5) * increment
            newValue = clamp(newValue, range[1], range[2])
            if newValue ~= currentValue then
                currentValue = newValue
                barFill.Size = UDim2.new(1, 0, (currentValue - range[1]) / (range[2] - range[1]), 0)
                barFill.Position = UDim2.new(0, 0, 1, -barFill.Size.Y.Offset)
                dragButton.Position = UDim2.new(0.5, -10, 0.2 + 0.6 * (1 - (currentValue - range[1]) / (range[2] - range[1])), 0)
                valueLabel.Text = tostring(currentValue) .. suffix
                pcall(callback, currentValue)
            end
        end

        dragButton.MouseButton1Down:Connect(function()
            dragging = true
            if dragConnection then dragConnection:Disconnect() end
            dragConnection = RunService.RenderStepped:Connect(function()
                if not dragging then
                    dragConnection:Disconnect()
                    dragConnection = nil
                    return
                end
                local mousePos = UIS:GetMouseLocation()
                updateSlider(Vector2.new(mousePos.X, mousePos.Y))
            end)
        end)

        barBg.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = true
                local mousePos = UIS:GetMouseLocation()
                updateSlider(Vector2.new(mousePos.X, mousePos.Y))
            end
        end)

        local inputEndedConn = UIS.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false
            end
        end)

        return {
            Set = function(newValue)
                newValue = clamp(newValue, range[1], range[2])
                currentValue = newValue
                barFill.Size = UDim2.new(1, 0, (currentValue - range[1]) / (range[2] - range[1]), 0)
                barFill.Position = UDim2.new(0, 0, 1, -barFill.Size.Y.Offset)
                dragButton.Position = UDim2.new(0.5, -10, 0.2 + 0.6 * (1 - (currentValue - range[1]) / (range[2] - range[1])), 0)
                valueLabel.Text = tostring(currentValue) .. suffix
                pcall(callback, currentValue)
            end,
            Destroy = function()
                if dragConnection then dragConnection:Disconnect() end
                if inputEndedConn then inputEndedConn:Disconnect() end
                sliderFrame:Destroy()
            end
        }
    end)
end

