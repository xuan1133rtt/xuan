-- 4. 高空掛機平台
local SAFE_POSITION = Vector3.new(3000, 3000, 3000)
local SYSTEM_CENTER = SAFE_POSITION + Vector3.new(0, 18, -45)
local PLATFORM_SIZE = 30
local NUM_NODES = 180
local NUM_LAYERS = 4
local OUTER_RADIUS = 20
local LAYER_SPACING = 4.5
local SIGMA, RHO, BETA = 10, 28, 8/3
local TIME_STEP = 0.008

local function CreateSphericalChaos()
    if not workspace:FindFirstChild("SafeAFKPlatform") then
        local platform = Instance.new("Part")
        platform.Name = "SafeAFKPlatform"
        platform.Size = Vector3.new(PLATFORM_SIZE, 1, PLATFORM_SIZE)
        platform.Position = SAFE_POSITION
        platform.Anchored = true
        platform.Transparency = 0.5
        platform.Material = Enum.Material.Glass
        platform.Color = Color3.fromRGB(5, 10, 20)
        platform.Parent = workspace
    end
    if workspace:FindFirstChild("SphericalChaosSystem") then
        workspace.SphericalChaosSystem:Destroy()
    end
    local systemModel = Instance.new("Model")
    systemModel.Name = "SphericalChaosSystem"
    systemModel.Parent = workspace
    local chaosNodes = {}
    local coreGlow = Instance.new("Part")
    coreGlow.Shape = Enum.PartType.Ball
    coreGlow.Size = Vector3.new(3.5, 3.5, 3.5)
    coreGlow.Color = Color3.fromRGB(255, 255, 255)
    coreGlow.Material = Enum.Material.Neon
    coreGlow.Anchored = true
    coreGlow.CanCollide = false
    coreGlow.Position = SYSTEM_CENTER
    coreGlow.Parent = systemModel
    local coreLight = Instance.new("PointLight")
    coreLight.Color = Color3.fromRGB(150, 200, 255)
    coreLight.Range = 50
    coreLight.Brightness = 4
    coreLight.Parent = coreGlow
    for i = 1, NUM_NODES do
        local node = Instance.new("Part")
        node.Shape = Enum.PartType.Ball
        node.Size = Vector3.new(0.3, 0.3, 0.3)
        node.Material = Enum.Material.Neon
        node.Anchored = true
        node.CanCollide = false
        node.Parent = systemModel
        local layerIndex = (i % NUM_LAYERS) + 1
        local targetRadius = OUTER_RADIUS - ((layerIndex - 1) * LAYER_SPACING)
        local hue = 0.6 + (layerIndex * 0.05)
        local saturation = 1 - (layerIndex * 0.15)
        node.Color = Color3.fromHSV(hue, math.clamp(saturation, 0, 1), 1)
        local att0 = Instance.new("Attachment", node)
        att0.Position = Vector3.new(0, 0.2, 0)
        local att1 = Instance.new("Attachment", node)
        att1.Position = Vector3.new(0, -0.2, 0)
        local trail = Instance.new("Trail")
        trail.Attachment0 = att0
        trail.Attachment1 = att1
        trail.Lifetime = 1.5 - (layerIndex * 0.25)
        trail.MinLength = 0.05
        trail.Color = ColorSequence.new(node.Color)
        trail.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0,0), NumberSequenceKeypoint.new(1,1)})
        trail.LightEmission = 1 + (layerIndex * 0.2)
        trail.Parent = node
        local initialX = 0.1 + (i * 0.05)
        local initialY = 0.1 - (i * 0.02)
        local initialZ = 0.1
        table.insert(chaosNodes, {
            part = node,
            x = initialX, y = initialY, z = initialZ,
            radius = targetRadius,
            speedMult = 0.5 + (layerIndex * 0.6)
        })
    end
    return chaosNodes, systemModel
end

local chaosNodes, systemModel = CreateSphericalChaos()
task.spawn(function()
    while true do
        task.wait(1/60)
        if not systemModel or not systemModel.Parent then
            chaosNodes, systemModel = CreateSphericalChaos()
        end
        local t = tick()
        local globalRot = CFrame.Angles(t * 0.05, t * 0.08, t * 0.02)
        for _, data in ipairs(chaosNodes) do
            if data.part then
                local dx = SIGMA * (data.y - data.x) * TIME_STEP
                local dy = (data.x * (RHO - data.z) - data.y) * TIME_STEP
                local dz = (data.x * data.y - BETA * data.z) * TIME_STEP
                data.x = data.x + dx
                data.y = data.y + dy
                data.z = data.z + dz
                local theta = data.x * 0.2 + (t * 0.8 * data.speedMult)
                local phi = data.y * 0.15
                local r = data.radius + (data.z * 0.08) - 1
                local plotX = r * math.sin(phi) * math.cos(theta)
                local plotY = r * math.cos(phi)
                local plotZ = r * math.sin(phi) * math.sin(theta)
                local localPos = Vector3.new(plotX, plotY, plotZ)
                local worldPos = (CFrame.new(SYSTEM_CENTER) * globalRot * CFrame.new(localPos)).Position
                data.part.CFrame = CFrame.new(worldPos)
            end
        end
    end
end)


