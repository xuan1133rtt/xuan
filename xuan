    if not emotes then
        warn("[MyCommander] 找不到 Emotes，無法自動改名")
        return
    end

    -- 列出所有 Emotes 物品供參考
    print("[MyCommander] 目前 Emotes 中的物品：")
    for _, v in ipairs(emotes:GetChildren()) do
        print("  - " .. v.Name)
    end

    -- 嘗試多種大小寫來找到來源
    local function findItem(name)
        local variants = {
            name,
            name:lower(),
            name:upper(),
            name:gsub("^%l", string.upper),
            name:gsub(" ", ""),
        }
        for _, v in ipairs(variants) do
            local item = emotes:FindFirstChild(v)
            if item then return item end
        end
        return nil
    end

    local sourceItem = findItem(SOURCE_NAME)
    if not sourceItem then
        warn("[MyCommander] 找不到來源表情：", SOURCE_NAME)
        return
    end

    -- 如果目標名稱已存在，但來源不是目標，則先刪除目標（危險操作，預設關閉）
    local targetItem = findItem(TARGET_NAME)
    if targetItem and targetItem ~= sourceItem then
        warn("[MyCommander] 目標名稱", TARGET_NAME, "已存在於其他物品，可能無法改名")
        -- 若不希望保留目標，可考慮刪除（但風險自負）
        -- pcall(function() targetItem:Destroy() end)
        -- return
    end

    -- 執行改名（加入重試）
    local maxRetries = 5
    for retry = 1, maxRetries do
        local success, err = pcall(function()
            sourceItem.Name = TARGET_NAME
        end)
        if success then
            print("[MyCommander] 成功將", SOURCE_NAME, "改名為", TARGET_NAME)
            return
        else
            warn("[MyCommander] 改名失敗 (嘗試", retry, ")：", err)
            task.wait(2) -- 等待後重試
        end
    end

    warn("[MyCommander] 改名失敗，已達最大重試次數")
end)

